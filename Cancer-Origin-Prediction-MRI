    {
      "cell_type": "code",
      "source": [
        "# =========================\n",
        "# CONFIG\n",
        "# =========================\n",
        "NORM_DIR = \"/content/drive/MyDrive/Lung_Normalized_ROI\"\n",
        "SAVE_CSV = \"/content/drive/MyDrive/lung_deep_features.csv\"\n",
        "\n",
        "MODALITIES = [\"t1ce\", \"flair\"]\n",
        "TARGET_DEPTH = 64\n",
        "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
